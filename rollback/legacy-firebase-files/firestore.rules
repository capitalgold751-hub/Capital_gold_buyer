rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All business data is accessed through authenticated Next.js server routes.
    // Firebase Admin SDK enforces application roles and bypasses client rules.
    // Direct browser/mobile Firestore access is intentionally denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
